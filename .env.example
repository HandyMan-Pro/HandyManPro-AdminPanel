APP_NAME="Handyman Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=America/New_York

IS_DUMMY_DATA=false

DB_CONNECTION=mysql
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=18616
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=
MYSQL_SSL_CA=true

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 Storage (S3-compatible)
FILESYSTEM_DRIVER=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=handyman-storage
AWS_URL=
AWS_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

DEFAULT_LANGUAGE=en

# OneSignal - User App
ONESIGNAL_API_KEY=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_CHANNEL_ID=

# OneSignal - Provider App
ONESIGNAL_ONESIGNAL_APP_ID_PROVIDER=
ONESIGNAL_ONESIGNAL_REST_API_KEY_PROVIDER=
ONESIGNAL_ONESIGNAL_CHANNEL_ID_PROVIDER=

APP_TIMEZONE=America/New_York
GOOGLE_MAPS_API_KEY=

LOG_CHANNEL=daily
LOG_LEVEL=error